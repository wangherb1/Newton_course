---
import { outlineSource } from '../../data/principiaOutline';
import { siteStatus } from '../../data/siteStatus';
---

<section class="home-section">
  <div class="section-heading">
    <p class="section-kicker">Project status</p>
    <h2>项目建设状态</h2>
  </div>
  <div class="status-panel">
    <p><strong>当前版本</strong><span>{siteStatus.version}</span></p>
    <p><strong>已完成</strong><span>{siteStatus.completed.join('、')}</span></p>
    <p><strong>进行中</strong><span>{siteStatus.inProgress.join('、')}</span></p>
    <p><strong>下一步</strong><span>{siteStatus.next.join('、')}</span></p>
    <p><strong>目录来源</strong><span>{outlineSource.sourceFile}</span></p>
    <p><strong>提取状态</strong><span>{outlineSource.candidateCount} 个目录候选项，仍需逐章人工校核</span></p>
  </div>
</section>
